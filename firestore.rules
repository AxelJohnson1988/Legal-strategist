rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidReminder(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.type in ['filing', 'court_date', 'other'] &&
             data.date is timestamp &&
             data.createdAt is timestamp;
    }

    function isValidDraftDocument(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.templateType in ['case_brief', 'motion_summary', 'discovery_plan'] &&
             data.content is map &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /reminders/{reminderId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(reminderId) && 
                    isValidReminder(incoming()) && 
                    incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && 
                    isOwner(existing().userId) && 
                    isValidReminder(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt;
      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /drafts/{draftId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(draftId) && 
                    isValidDraftDocument(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      
      allow update: if isSignedIn() && 
                    isOwner(existing().userId) && 
                    isValidDraftDocument(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().templateType == existing().templateType &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
